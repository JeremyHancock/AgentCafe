# AgentCafe — Environment Variables
#
# Copy to .env and fill in required values.
# See also: fly.toml (production config), docker-compose.yml (local multi-container).

# ─── Server ───────────────────────────────────────────────────────────────────
CAFE_HOST=127.0.0.1
CAFE_PORT=8000
CAFE_DB_PATH=agentcafe.db

# ─── Secrets (REQUIRED in production) ─────────────────────────────────────────
# Passport JWT signing — must be ≥32 bytes, stable across restarts
PASSPORT_SIGNING_SECRET=
# Admin API key for /issuer endpoints
ISSUER_API_KEY=
# AES-256-GCM key for encrypting stored backend credentials (hex or base64)
CAFE_ENCRYPTION_KEY=

# ─── RSA Keys (REQUIRED in production) ────────────────────────────────────────
# Provide either the key contents or a file path, not both.
# Passport RS256 signing key (PEM-encoded)
PASSPORT_RSA_PRIVATE_KEY=
PASSPORT_RSA_KEY_FILE=
# Artifact signing key (PEM-encoded)
ARTIFACT_RSA_PRIVATE_KEY=
ARTIFACT_RSA_KEY_FILE=

# ─── Auth ─────────────────────────────────────────────────────────────────────
USE_REAL_PASSPORT=true
ALLOW_PASSWORD_AUTH=false

# ─── WebAuthn / Passkeys ─────────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AgentCafe
WEBAUTHN_ORIGIN=http://localhost:8000

# ─── Demo Backends (local dev only) ──────────────────────────────────────────
HOTEL_BACKEND_HOST=127.0.0.1
HOTEL_BACKEND_PORT=8001
LUNCH_BACKEND_HOST=127.0.0.1
LUNCH_BACKEND_PORT=8002
HOME_SERVICE_BACKEND_HOST=127.0.0.1
HOME_SERVICE_BACKEND_PORT=8003

# ─── Optional ────────────────────────────────────────────────────────────────
# CAFE_SECURE_COOKIES=false              # Set to "true" in production (HTTPS) for Secure cookie flag
# CORS_ALLOWED_ORIGINS=*                # Restrict in production (e.g., https://agentcafe.io)
# CAFE_LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
# CAFE_LOG_FORMAT=text                  # "text" for dev, "json" for production
# CAFE_PUBLIC_URL=                      # Base URL for absolute links in API responses
# QUARANTINE_DAYS=7                     # Days before newly published services go live
# OPENAI_API_KEY=                       # For wizard AI enrichment (LiteLLM)
# CAFE_DESIGN_DIR=                      # Override path to built-in service designs
