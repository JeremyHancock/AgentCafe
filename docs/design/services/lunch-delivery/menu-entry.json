{
  "service_id": "quickbite-delivery",
  "name": "QuickBite Delivery",
  "category": "food-delivery",
  "capability_tags": ["food", "delivery", "restaurants", "lunch"],
  "description": "Order food delivery from nearby restaurants. Browse menus, place orders, track deliveries, and manage cancellations. Delivers within 30 minutes in supported areas.",
  "actions": [
    {
      "action_id": "browse-menu",
      "description": "Search available lunch options from nearby restaurants. Filter by cuisine, dietary preferences, price range, and delivery time. Returns menu items with pricing and estimated delivery.",
      "required_inputs": [
        {
          "name": "delivery_address",
          "type": "string",
          "description": "Delivery address to find nearby restaurants",
          "example": "200 Congress Ave, Austin, TX 78701"
        }
      ],
      "cost": {
        "required_scopes": ["quickbite-delivery:browse-menu"],
        "human_authorization_required": false,
        "limits": {"rate_limit": "60/minute"}
      },
      "example_response": {
        "items": [
          {
            "item_id": "qb-ceasar-lg-001",
            "restaurant_name": "Green Fork Kitchen",
            "item_name": "Chicken Caesar Salad",
            "description": "Grilled chicken breast, romaine, parmesan, house-made Caesar dressing, croutons",
            "price": 13.50,
            "currency": "USD",
            "estimated_delivery_minutes": 25,
            "dietary_tags": ["high-protein"],
            "rating": 4.7
          }
        ],
        "total_results": 1
      }
    },
    {
      "action_id": "place-order",
      "description": "Place a food delivery order. Creates a real order with financial commitment. Includes subtotal, delivery fee, tax, and optional tip.",
      "required_inputs": [
        {
          "name": "items",
          "type": "array",
          "description": "Array of items to order, each with item_id and quantity",
          "example": [{"item_id": "qb-ceasar-lg-001", "quantity": 1}]
        },
        {
          "name": "delivery_address",
          "type": "string",
          "description": "Full delivery address",
          "example": "200 Congress Ave, Suite 400, Austin, TX 78701"
        },
        {
          "name": "contact_name",
          "type": "string",
          "description": "Name for the delivery",
          "example": "Jane Smith"
        },
        {
          "name": "contact_phone",
          "type": "string",
          "description": "Phone number for delivery updates",
          "example": "+1-512-555-0199"
        }
      ],
      "cost": {
        "required_scopes": ["quickbite-delivery:place-order"],
        "human_authorization_required": true,
        "limits": {"rate_limit": "10/minute"}
      },
      "example_response": {
        "order_id": "QB-20260315-H8K2",
        "status": "confirmed",
        "restaurant_name": "Green Fork Kitchen",
        "items": [
          {
            "item_name": "Chicken Caesar Salad",
            "quantity": 1,
            "price": 13.50
          }
        ],
        "subtotal": 13.50,
        "delivery_fee": 2.99,
        "tip": 3.00,
        "tax": 1.11,
        "total": 20.60,
        "currency": "USD",
        "estimated_delivery": "2026-03-15T12:25:00Z",
        "tracking_available": true
      }
    },
    {
      "action_id": "track-order",
      "description": "Get the current status and estimated arrival time for an active delivery order. Includes driver info and real-time status updates.",
      "required_inputs": [
        {
          "name": "order_id",
          "type": "string",
          "description": "Order identifier from the order confirmation",
          "example": "QB-20260315-H8K2"
        }
      ],
      "cost": {
        "required_scopes": ["quickbite-delivery:track-order"],
        "human_authorization_required": false,
        "limits": {"rate_limit": "30/minute"}
      },
      "example_response": {
        "order_id": "QB-20260315-H8K2",
        "status": "in_transit",
        "status_message": "Your driver is on the way",
        "estimated_arrival": "2026-03-15T12:25:00Z",
        "driver_name": "Carlos M.",
        "last_updated": "2026-03-15T12:15:00Z"
      }
    },
    {
      "action_id": "cancel-order",
      "description": "Cancel a pending order that hasn't started preparation. Full refund if cancelled before preparation begins.",
      "required_inputs": [
        {
          "name": "order_id",
          "type": "string",
          "description": "Order identifier from the order confirmation",
          "example": "QB-20260315-H8K2"
        }
      ],
      "cost": {
        "required_scopes": ["quickbite-delivery:cancel-order"],
        "human_authorization_required": true,
        "limits": {"rate_limit": "10/minute"}
      },
      "example_response": {
        "order_id": "QB-20260315-H8K2",
        "status": "cancelled",
        "refund_amount": 20.60,
        "currency": "USD"
      }
    }
  ]
}
